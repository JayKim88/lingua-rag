# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL (Railway provides this)
DATABASE_URL=postgresql://user:password@host:5432/linguarag

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
CLAUDE_MODEL=claude-sonnet-4-6

# CORS — comma-separated list of allowed frontend origins.
# Use "https://*.vercel.app" for Vercel preview deployments (handled via regex).
# Example production value:
#   FRONTEND_URL=https://my-app.vercel.app,https://*.vercel.app
FRONTEND_URL=http://localhost:3000